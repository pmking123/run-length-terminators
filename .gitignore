# =============================================================================
# .gitignore
#
# Policy: git carries the code, the frozen inputs, and every SMALL derived table
# a reader needs to inspect the results. Large regenerable intermediates stay out
# of git and are archived in full on Zenodo (the DOI points at the complete tree).
#
# Everything excluded here is a deterministic function of data/gb_cache* + scripts/,
# and is regenerated by run_all.sh.
#
# Before your first commit, verify what is actually staged:
#     git status --short
#     git check-ignore -v analysis_final/boundary_enrichment/run_table.csv.gz
# =============================================================================

# --- Large derived intermediates (archived on Zenodo, not in git) ------------
# run table: ~842 MB raw / ~40 MB gzipped. Regenerated by boundary_enrichment.py.
analysis_final/boundary_enrichment/run_table.csv
analysis_final/boundary_enrichment/run_table.csv.gz
# per-boundary detail (~2.2 MB); the genome/enrichment summaries are kept.
analysis_final/boundary_enrichment/boundary_summary.csv

# --- Predictor input files (regenerated in seconds from the GenBank cache) ----
analysis_final/transterm_inputs/
analysis_final/transterm_inputs_mono/

# --- Verification / scratch runs ---------------------------------------------
# run_all.sh writes to whatever OUTDIR you give it; keep re-runs untracked.
analysis_verify/
analysis_test/
analysis_scratch/

# --- Python -------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# --- Editors / OS --------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/

# --- Cluster job detritus ------------------------------------------------------
slurm-*.out
*.o[0-9]*
*.e[0-9]*
core.[0-9]*

# =============================================================================
# INTENTIONALLY TRACKED — do not add ignore rules for these:
#
#   data/gb_cache/, data/gb_cache_mono/        FROZEN INPUTS (the analysed records)
#   data/accessions_*.txt, data/features.csv   FROZEN INPUTS (the pinned set)
#   scripts/*.py                               all analysis code
#
#   analysis_final/boundary_enrichment/genome_summary.csv    dataset description
#   analysis_final/boundary_composition_controls/*           Table 1
#   analysis_final/per_genome_paired/*                       pseudoreplication control
#   analysis_final/**/terminator_benchmark_summary.csv       Table 2
#   analysis_final/**/terminator_candidates.csv              Figure 2a inputs
#   analysis_final/**/terminator_sensitivity_sweep.csv       k-sweep
#   analysis_final/distance_profile/*                        E_k(d) profiles
#   analysis_final/random_boundary_control/*                 rotation/uniform nulls
#   analysis_final/threeprime_motifs/*                       Figure 1
#   analysis_final/transterm_*.tt                            TransTermHP output (small)
#   analysis_final/rnie_*.tbl                                RNIE/cmsearch output (small)
#   analysis_final/reference_rnie_*.bed                      parsed references (small)
# =============================================================================
